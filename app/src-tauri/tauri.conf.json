{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voicebox",
  "version": "0.1.0",
  "identifier": "com.voicebox.app",
  "build": {
    "beforeDevCommand": "bun node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun node_modules/typescript/bin/tsc -p tsconfig.json && bun node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["../../preset-voices"],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/custom.nsh"
      }
    }
  }
}
