{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voicebox",
  "version": "0.1.0",
  "identifier": "com.voicebox.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voicebox",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../../backend", "../../preset-voices"]
  }
}
